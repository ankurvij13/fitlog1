{
  "expo": {
    "name": "JussaFit",
    "slug": "fitlog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/jussafit.png",
    "scheme": "fitlogankuromobile1",
    "userInterfaceStyle": "automatic",
    "updates": {
      "enabled": false
    },
    "ios": {
      "icon": "./assets/images/jussafit.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/jussafit.png",
        "backgroundColor": "#0B1220"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ankuroapps.fitlog"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "29e1449f-9464-4f30-81e0-b45514132280"
      }
    },
    "owner": "ankuro-apps"
  }
}
